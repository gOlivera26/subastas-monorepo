{
  "OTEL_SERVICE_NAME": "api-gateway",
  "OTEL_EXPORTER_OTLP_ENDPOINT": "http://otel-collector:4317",
  "OTEL_EXPORTER_OTLP_LOGS_ENDPOINT": "http://otel-collector:4318/v1/logs",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "http://localhost:4201"
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "UserRoute": {
        "ClusterId": "IdentityCluster",
        "Match": { "Path": "/api/User/{**catch-all}" }
      },
      "AuthRoute": {
        "ClusterId": "IdentityCluster",
        "Match": { "Path": "/api/Auth/{**catch-all}" }
      },
      "RoleRoute": {
        "ClusterId": "IdentityCluster",
        "Match": { "Path": "/api/Role/{**catch-all}" }
      },
      "OrgRoute": {
        "ClusterId": "IdentityCluster",
        "Match": { "Path": "/api/Organization/{**catch-all}" }
      },
      "ProviderRoute": {
        "ClusterId": "ProvidersCluster",
        "Match": { "Path": "/api/Provider/{**catch-all}" }
      },
      "RubroRoute": {
        "ClusterId": "ProvidersCluster",
        "Match": { "Path": "/api/Rubro/{**catch-all}" }
      },
      "DomicilioRoute": {
        "ClusterId": "ProvidersCluster",
        "Match": { "Path": "/api/Domicilio/{**catch-all}" }
      },
      "VigenciaRoute": {
        "ClusterId": "IdentityCluster",
        "Match": { "Path": "/api/Vigencia/{**catch-all}" }
      },
      "UnidadAdmRoute": {
        "ClusterId": "IdentityCluster",
        "Match": { "Path": "/api/UnidadAdministrativa/{**catch-all}" }
      },
      "ObjetoGastoRoute": {
        "ClusterId": "IdentityCluster",
        "Match": { "Path": "/api/ObjetoGasto/{**catch-all}" }
      },
      "CatalogoBienRoute": {
        "ClusterId": "IdentityCluster",
        "Match": { "Path": "/api/CatalogoBien/{**catch-all}" }
      },
      "CategoriaProgRoute": {
        "ClusterId": "IdentityCluster",
        "Match": { "Path": "/api/CategoriaProgramatica/{**catch-all}" }
      },
      "MonedaRoute": {
        "ClusterId": "IdentityCluster",
        "Match": { "Path": "/api/Moneda/{**catch-all}" }
      },
      "SubResponsableRoute": {
        "ClusterId": "IdentityCluster",
        "Match": { "Path": "/api/SubResponsable/{**catch-all}" }
      },
      "GarantiaRoute": {
        "ClusterId": "LicitacionesCluster",
        "Match": { "Path": "/api/Garantia/{**catch-all}" }
      },
      "ReservaRoute": {
        "ClusterId": "LicitacionesCluster",
        "Match": { "Path": "/api/Reserva/{**catch-all}" }
      },
      "ReservaDetalleRoute": {
        "ClusterId": "LicitacionesCluster",
        "Match": { "Path": "/api/ReservaDetalle/{**catch-all}" }
      },
      "CotizacionRoute": {
        "ClusterId": "LicitacionesCluster",
        "Match": { "Path": "/api/Cotizacion/{**catch-all}" }
      },
      "CotizacionPublicaRoute": {
        "ClusterId": "LicitacionesCluster",
        "Match": { "Path": "/api/CotizacionPublica/{**catch-all}" }
      },
      "OfertaSubastaRoute": {
        "ClusterId": "LicitacionesCluster",
        "Match": { "Path": "/api/OfertaSubasta/{**catch-all}" }
      },
      "GanadorRoute": {
        "ClusterId": "LicitacionesCluster",
        "Match": { "Path": "/api/Ganador/{**catch-all}" }
      },
      "ReporteRoute": {
        "ClusterId": "ReportingCluster",
        "Match": { "Path": "/api/Reporte/{**catch-all}" }
      },
      "SubastaSignalRRooute": {
        "ClusterId": "LicitacionesCluster",
        "Match": { "Path": "/signalr/subastas/{**catch-all}" }
      }
    },
    "Clusters": {
      "IdentityCluster": {
        "Destinations": {
          "IdentityApi": {
            "Address": "http://identity:8080"
          }
        },
        "HealthCheck": {
          "Passive": {
            "Enabled": true,
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:00:30"
          }
        }
      },
      "ProvidersCluster": {
        "Destinations": {
          "ProvidersApi": {
            "Address": "http://providers:8080"
          }
        },
        "HealthCheck": {
          "Passive": {
            "Enabled": true,
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:00:30"
          }
        }
      },
      "LicitacionesCluster": {
        "Destinations": {
          "LicitacionesApi": {
            "Address": "http://licitaciones:8080"
          }
        },
        "HealthCheck": {
          "Passive": {
            "Enabled": true,
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:00:30"
          }
        }
      },
      "ReportingCluster": {
        "Destinations": {
          "ReportingApi": {
            "Address": "http://reporting:8080"
          }
        }
      }
    }
  }
}
