@model PortalSubastas.Reporting.Domain.Models.ReporteLicitacion
@{
    var fechaArgentina = Model.FechaEmision.ToOffset(TimeSpan.FromHours(-3)).ToString("dd/MM/yyyy HH:mm");
}
<!doctype html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>@Model.Titulo</title>
    <style>
        * { box-sizing: border-box; }
        body {
            font-family: Arial, Helvetica, sans-serif;
            color: #111827;
            margin: 0;
            padding: 0;
            font-size: 12px;
        }
        .page { padding: 24px 28px; }
        header {
            border-bottom: 2px solid #1f2937;
            margin-bottom: 20px;
            padding-bottom: 12px;
        }
        .brand {
            color: #4b5563;
            font-size: 11px;
            letter-spacing: .08em;
            text-transform: uppercase;
        }
        h1 {
            margin: 6px 0 0;
            font-size: 22px;
        }
        .meta {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            margin: 16px 0;
        }
        .meta-card {
            border: 1px solid #d1d5db;
            border-radius: 6px;
            padding: 10px;
        }
        .label {
            color: #6b7280;
            display: block;
            font-size: 10px;
            margin-bottom: 4px;
            text-transform: uppercase;
        }
        .value { font-weight: 700; }
        .notice {
            background: #fff7ed;
            border: 1px solid #fed7aa;
            border-radius: 6px;
            color: #9a3412;
            margin: 18px 0;
            padding: 10px 12px;
        }
        table {
            border-collapse: collapse;
            margin-top: 14px;
            width: 100%;
        }
        th, td {
            border: 1px solid #d1d5db;
            padding: 8px;
            text-align: left;
        }
        th {
            background: #f3f4f6;
            font-size: 11px;
            text-transform: uppercase;
        }
        .number { text-align: right; }
    </style>
</head>
<body>
    <main class="page">
        <header>
            <div class="brand">Portal Subastas · Reportería</div>
            <h1>@Model.Titulo</h1>
        </header>

        <section class="meta">
            <div class="meta-card">
                <span class="label">Número</span>
                <span class="value">@Model.Numero</span>
            </div>
            <div class="meta-card">
                <span class="label">Estado</span>
                <span class="value">@Model.Estado</span>
            </div>
            <div class="meta-card">
                <span class="label">Emitido</span>
                <span class="value">@fechaArgentina</span>
            </div>
        </section>

        <section class="notice">
            Template Razor base. Falta conectar el origen real de datos de Licitaciones para reemplazar el modelo de ejemplo.
        </section>

        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Descripción</th>
                    <th class="number">Cantidad</th>
                    <th>Unidad</th>
                    <th class="number">Precio estimado</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var renglon in Model.Renglones)
                {
                    <tr>
                        <td>@renglon.Numero</td>
                        <td>@renglon.Descripcion</td>
                        <td class="number">@renglon.Cantidad.ToString("N2")</td>
                        <td>@renglon.UnidadMedida</td>
                        <td class="number">@renglon.PrecioEstimado.ToString("C")</td>
                    </tr>
                }
            </tbody>
        </table>
    </main>
</body>
</html>
