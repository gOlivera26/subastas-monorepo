@model PortalSubastas.Reporting.Domain.Models.ActaPrelacionReport
@{
    var culture = new System.Globalization.CultureInfo("es-AR");
    string Fecha(DateTime? value) => value.HasValue ? value.Value.ToString("dd/MM/yyyy HH:mm", culture) : "-";
    string Money(decimal value) => value.ToString("C", culture);
    string Number(decimal value) => value.ToString("N2", culture);
    var fechaEmision = Model.Cabecera.FechaEmision.ToOffset(TimeSpan.FromHours(-3)).ToString("dd/MM/yyyy HH:mm", culture);
}
<!doctype html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Acta de prelacion @Model.Cabecera.NumeroCotizacion</title>
    <style>
        * { box-sizing: border-box; }
        body {
            color: #111827;
            font-family: Arial, Helvetica, sans-serif;
            font-size: 11px;
            margin: 0;
        }
        .page { padding: 24px 28px; }
        header {
            border-bottom: 2px solid #111827;
            margin-bottom: 16px;
            padding-bottom: 10px;
        }
        .brand {
            color: #6b7280;
            font-size: 10px;
            letter-spacing: .08em;
            text-transform: uppercase;
        }
        h1 {
            font-size: 20px;
            margin: 6px 0 4px;
        }
        h2 {
            border-bottom: 1px solid #d1d5db;
            font-size: 14px;
            margin: 20px 0 8px;
            padding-bottom: 4px;
        }
        .subtitle { color: #4b5563; }
        .grid {
            display: grid;
            gap: 8px;
            grid-template-columns: repeat(3, 1fr);
            margin: 14px 0;
        }
        .card {
            border: 1px solid #d1d5db;
            border-radius: 5px;
            padding: 8px;
        }
        .label {
            color: #6b7280;
            display: block;
            font-size: 9px;
            margin-bottom: 3px;
            text-transform: uppercase;
        }
        .value { font-weight: 700; }
        table {
            border-collapse: collapse;
            margin-top: 8px;
            page-break-inside: auto;
            width: 100%;
        }
        tr { page-break-inside: avoid; page-break-after: auto; }
        th, td {
            border: 1px solid #d1d5db;
            padding: 6px;
            text-align: left;
            vertical-align: top;
        }
        th {
            background: #f3f4f6;
            font-size: 9px;
            text-transform: uppercase;
        }
        .number { text-align: right; white-space: nowrap; }
        .muted { color: #6b7280; }
        .empty {
            border: 1px dashed #d1d5db;
            color: #6b7280;
            padding: 8px;
        }
    </style>
</head>
<body>
<main class="page">
    <header>
        <div class="brand">Portal Subastas · Reporteria</div>
        <h1>Acta de prelacion</h1>
        <div class="subtitle">@Model.Cabecera.Titulo</div>
    </header>

    <section class="grid">
        <div class="card"><span class="label">Cotizacion</span><span class="value">@Model.Cabecera.NumeroCotizacion</span></div>
        <div class="card"><span class="label">Estado</span><span class="value">@Model.Cabecera.Estado</span></div>
        <div class="card"><span class="label">Tipo</span><span class="value">@Model.Cabecera.TipoContratacion</span></div>
        <div class="card"><span class="label">Criterio</span><span class="value">@Model.Cabecera.CriterioAdjudicacion</span></div>
        <div class="card"><span class="label">Unidad administrativa</span><span class="value">@Model.Cabecera.UnidadAdministrativa</span></div>
        <div class="card"><span class="label">Expediente</span><span class="value">@(Model.Cabecera.NumeroExpediente ?? "-")</span></div>
        <div class="card"><span class="label">Inicio</span><span class="value">@Fecha(Model.Cabecera.FechaInicioSubasta)</span></div>
        <div class="card"><span class="label">Fin</span><span class="value">@Fecha(Model.Cabecera.FechaFinalizacionSubasta)</span></div>
        <div class="card"><span class="label">Emitido</span><span class="value">@fechaEmision</span></div>
    </section>

    <h2>Detalle de items / renglones</h2>
    <table>
        <thead>
        <tr>
            <th>#</th>
            <th>Detalle</th>
            <th class="number">Cantidad</th>
            <th class="number">Precio base</th>
            <th class="number">Total base</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var d in Model.Detalles)
        {
            <tr>
                <td>@d.Numero</td>
                <td>@d.Descripcion</td>
                <td class="number">@Number(d.Cantidad)</td>
                <td class="number">@Money(d.PrecioBase)</td>
                <td class="number">@Money(d.TotalBase)</td>
            </tr>
        }
        </tbody>
    </table>

    <h2>Ofertas iniciales reconstruidas</h2>
    @if (!Model.OfertasIniciales.Any())
    {
        <div class="empty">No hay ofertas registradas para reconstruir ofertas iniciales.</div>
    }
    else
    {
        <table>
            <thead>
            <tr>
                <th>#</th>
                <th>Proveedor</th>
                <th>Detalle</th>
                <th class="number">Monto</th>
                <th class="number">Total</th>
                <th>Fecha</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var o in Model.OfertasIniciales)
            {
                <tr>
                    <td>@o.NumeroOferta</td>
                    <td>@o.Proveedor <span class="muted">@(string.IsNullOrWhiteSpace(o.Cuit) ? "" : $"({o.Cuit})")</span></td>
                    <td>@o.NumeroDetalle - @o.Detalle</td>
                    <td class="number">@Money(o.Monto)</td>
                    <td class="number">@Money(o.Total)</td>
                    <td>@o.FechaOferta.ToString("dd/MM/yyyy HH:mm:ss", culture)</td>
                </tr>
            }
            </tbody>
        </table>
    }

    <h2>Historial de ofertas</h2>
    @if (!Model.HistorialOfertas.Any())
    {
        <div class="empty">No hay historial de ofertas registrado.</div>
    }
    else
    {
        <table>
            <thead>
            <tr>
                <th>#</th>
                <th>Proveedor</th>
                <th>Detalle</th>
                <th class="number">Monto</th>
                <th class="number">Total</th>
                <th>Fecha</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var o in Model.HistorialOfertas)
            {
                <tr>
                    <td>@o.NumeroOferta</td>
                    <td>@o.Proveedor <span class="muted">@(string.IsNullOrWhiteSpace(o.Cuit) ? "" : $"({o.Cuit})")</span></td>
                    <td>@o.NumeroDetalle - @o.Detalle</td>
                    <td class="number">@Money(o.Monto)</td>
                    <td class="number">@Money(o.Total)</td>
                    <td>@o.FechaOferta.ToString("dd/MM/yyyy HH:mm:ss", culture)</td>
                </tr>
            }
            </tbody>
        </table>
    }

    <h2>Ganadores / adjudicacion</h2>
    @if (!Model.Ganadores.Any())
    {
        <div class="empty">No hay ganadores cargados para esta subasta.</div>
    }
    else
    {
        <table>
            <thead>
            <tr>
                <th>Proveedor</th>
                <th>Detalle</th>
                <th class="number">Cantidad adjudicada</th>
                <th class="number">Monto ganador</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var g in Model.Ganadores)
            {
                <tr>
                    <td>@g.Proveedor <span class="muted">@(string.IsNullOrWhiteSpace(g.Cuit) ? "" : $"({g.Cuit})")</span></td>
                    <td>@g.NumeroDetalle - @g.Detalle</td>
                    <td class="number">@Number(g.CantidadAdjudicada)</td>
                    <td class="number">@Money(g.MontoGanador)</td>
                </tr>
            }
            </tbody>
        </table>
    }
</main>
</body>
</html>
